# Uptime Kuma image tag. Pin a reviewed version instead of using latest.
UPTIME_KUMA_IMAGE_TAG=2.4.0

# Bind to localhost by default. Use 0.0.0.0 only when an external firewall or reverse proxy controls access.
UPTIME_KUMA_HOST_BIND=127.0.0.1
UPTIME_KUMA_HOST_PORT=3001
UPTIME_KUMA_CONTAINER_PORT=3001

# Runtime settings.
TZ=Asia/Makassar
UPTIME_KUMA_CONTAINER_NAME=uptime-kuma
UPTIME_KUMA_DATA_DIR=./data

# Backup settings used by scripts/backup.sh and scripts/restore.sh.
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
